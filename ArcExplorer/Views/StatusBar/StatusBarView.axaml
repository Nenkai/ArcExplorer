<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="40"
             xmlns:VMs="using:ArcExplorer.ViewModels.StatusBar"
             x:Class="ArcExplorer.Views.StatusBarView"
             x:DataType="VMs:StatusBarViewModel"
             x:CompileBindings="True">
  <Design.DataContext>
		<VMs:StatusBarViewModel/>
  </Design.DataContext>
    <StackPanel Spacing="2" Orientation="Horizontal" Margin="6,0,0,0" Background="{DynamicResource SystemChromeAltLowColor}">
        <Label Content="{Binding LeftStatus}"/>
        <Border BorderThickness="1,0,0,0" BorderBrush="DarkGray" Margin="4,6"/>
		<Label Content="{Binding Message}"/>
    </StackPanel>
	
</UserControl>
