<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:ArcExplorer.Views"
        xmlns:dialogs="using:AvaloniaDialogs.Views"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="ArcExplorer.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        WindowStartupLocation="CenterScreen"
        Title="ArcExplorer"
        FontFamily="$Default">
    <Window.Resources>
		<ResourceDictionary>
			<StyleInclude x:Key="CustomStyle" Source="CustomStyle.axaml"/>
		</ResourceDictionary>
	</Window.Resources>

    <dialogs:ReactiveDialogHost CloseOnClickAway="True">
        <Grid>
	 		<views:MainView />
            <dialogs:Snackbar Name="Snackbar"/>
        </Grid>
    </dialogs:ReactiveDialogHost >
</Window>
